<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔀 Detail Split Bill"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/tvDetailSplitTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Judul" android:textColor="@color/accent_green"
        android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp">

        <TextView android:id="@+id/tvDetailSplitTotal"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Total: Rp 0" android:textColor="@color/text_secondary" android:textSize="14sp"/>

        <TextView android:id="@+id/tvDetailPerPerson"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Per orang: Rp 0" android:textColor="@color/accent_green"
            android:textSize="14sp" android:textStyle="bold"/>
    </LinearLayout>

    <TextView android:id="@+id/tvDetailPaidStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="0/0 sudah bayar" android:textColor="@color/warning_color"
        android:textSize="13sp" android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"
        android:background="@drawable/bg_chip"
        android:layout_marginBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDetailMembers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnDetailClose"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:text="Tutup"
        android:textColor="@color/bg_primary" android:backgroundTint="@color/accent_green"
        app:cornerRadius="12dp"/>
</LinearLayout>
