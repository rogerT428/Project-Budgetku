<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📊 Laporan Keuangan"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvReportContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="@color/bg_secondary"
            android:padding="12dp"/>
    </ScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="2">

        <Button android:id="@+id/btnCloseReport"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginEnd="8dp" android:text="Tutup"
            android:textColor="@color/text_secondary" android:backgroundTint="@color/bg_card_elevated"
            app:cornerRadius="12dp"/>

        <Button android:id="@+id/btnShareReport"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="📤 Bagikan"
            android:textColor="@color/bg_primary" android:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>
