<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 Tambah Budget Goal"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Kategori" android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerBudgetCategory"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Batas Budget Bulanan (Rp)" android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etBudgetLimit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Contoh: 500000"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:inputType="numberDecimal"
        android:layout_marginBottom="20dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="2">

        <Button
            android:id="@+id/btnCancelBudget"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginEnd="8dp" android:text="Batal"
            android:textColor="@color/text_secondary" android:backgroundTint="@color/bg_card_elevated"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnSaveBudget"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="Simpan"
            android:textColor="@color/bg_primary" android:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>
