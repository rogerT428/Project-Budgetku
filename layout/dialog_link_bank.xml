<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔗 Hubungkan Rekening Bank"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saldo akan otomatis berubah setiap ada transaksi"
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"/>

        <!-- Bank Selection -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pilih Bank" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerBankType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Account Number -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nomor Rekening" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etAccountNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Contoh: 1234567890"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="16dp"
            android:inputType="number"
            android:layout_marginBottom="6dp"/>

        <!-- Account number validation indicator -->
        <TextView
            android:id="@+id/tvAccountValidation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:layout_marginBottom="12dp"/>

        <!-- Account Holder Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nama Pemilik Rekening" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etAccountHolder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Nama sesuai buku tabungan"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName|textCapWords"
            android:layout_marginBottom="16dp"/>

        <!-- Initial Balance -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Saldo Saat Ini (Rp)" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Masukkan saldo rekening Anda sekarang. Setelah ini, saldo akan otomatis\nbertambah saat ada pemasukan dan berkurang saat ada pengeluaran."
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etInitialBalance"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Contoh: 1500000.50"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="16dp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="20dp"/>

        <!-- Info box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️ Bagaimana cara kerjanya?"
                android:textColor="@color/accent_green"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Saldo awal = nilai yang kamu masukkan sekarang\n• Setiap transaksi MASUK → saldo otomatis bertambah\n• Setiap transaksi KELUAR → saldo otomatis berkurang\n• SMS dari bank akan langsung dicatat otomatis"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2">

            <Button android:id="@+id/btnCancelLink"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:layout_marginEnd="8dp" android:text="Batal"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/bg_card_elevated"
                app:cornerRadius="12dp"/>

            <Button android:id="@+id/btnLinkAccount"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="🔗 Hubungkan"
                android:textColor="@color/bg_primary"
                android:backgroundTint="@color/accent_green"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
