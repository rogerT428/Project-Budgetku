<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Profile Header Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Avatar -->
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="👤"
                    android:textSize="40sp"
                    android:gravity="center"
                    android:background="@drawable/bg_circle"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengguna BudgetKu"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- Premium Badge -->
                <LinearLayout
                    android:id="@+id/llPremiumBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#20FFD700"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ PREMIUM"
                        android:textColor="#FFD700"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvProfileSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelola keuangan dengan bijak 💪"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:text="✏️ Edit Nama"
                        android:textSize="12sp"
                        android:textColor="@color/accent_green"
                        android:backgroundTint="@color/bg_card_elevated"
                        app:cornerRadius="18dp"/>

                    <Button
                        android:id="@+id/btnOpenMyProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="👤 Profil Lengkap"
                        android:textSize="12sp"
                        android:textColor="@color/bg_primary"
                        android:backgroundTint="@color/accent_green"
                        app:cornerRadius="18dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tvStatTransactions" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0" android:textColor="@color/accent_green"
                        android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Transaksi" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tvStatSavings" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0" android:textColor="@color/saving_color"
                        android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tabungan" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tvStatBudgets" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0" android:textColor="@color/warning_color"
                        android:textSize="22sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Budget" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Settings Menu -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnChangePIN"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🔒   Ubah PIN Keamanan"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp"/>

                <Button
                    android:id="@+id/btnManageCategories"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🗂️   Kelola Kategori"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp"/>

                <Button
                    android:id="@+id/btnExportReport"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="📊   Export Laporan Keuangan"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp"/>

                <!-- NEW: SMS Auto-Read Bank Transactions -->
                <Button
                    android:id="@+id/btnSmsAutoRead"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="📱   Auto Baca Transaksi Bank (SMS)"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="@color/accent_green"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>


                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp"/>

                <Button
                    android:id="@+id/btnAbout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="ℹ️   Tentang BudgetKu"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp"/>

                <!-- Premium Upgrade Button -->
                <Button
                    android:id="@+id/btnGoPremium"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="⭐   Beli Fitur Premium"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="#FFD700"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp"/>

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🚪   Keluar / Logout"
                    android:textAlignment="textStart"
                    android:paddingStart="20dp"
                    android:textColor="#FF4D4F"
                    android:backgroundTint="@color/bg_card"
                    android:gravity="center_vertical"
                    style="?attr/borderlessButtonStyle"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
