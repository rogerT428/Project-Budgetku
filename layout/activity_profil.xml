<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ===== HEADER SECTION ===== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="@drawable/bg_profile_header">

            <!-- Tombol Back -->
            <ImageButton
                android:id="@+id/btnBackProfil"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_card"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="@color/text_primary"
                android:contentDescription="Kembali" />

            <!-- Avatar Circle -->
            <FrameLayout
                android:id="@+id/flAvatarProfil"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="30dp"
                android:layout_centerInParent="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatarProfil"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:padding="3dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleAppearance"
                    android:background="@drawable/bg_avatar_border"
                    android:src="@android:drawable/ic_menu_camera"
                    android:tint="#484F58" />

                <TextView
                    android:id="@+id/tvAvatarInitialProfil"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:text="👤"
                    android:textSize="50sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:background="@drawable/bg_avatar_border" />

                <!-- Badge Camera Icon -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnChangePhoto"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    app:fabCustomSize="32dp"
                    app:elevation="2dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:backgroundTint="@color/accent_green"
                    app:tint="@color/bg_primary"
                    android:contentDescription="Ubah Foto" />
            </FrameLayout>

            <!-- Nama dan Username di bawah avatar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/flAvatarProfil"
                android:layout_centerHorizontal="true"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvProfilNama"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Pengguna"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfilUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@username"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- ===== NIM BADGE ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓 "
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvProfilNim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM: 00000000000"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ===== LABEL INFORMASI PRIBADI ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INFORMASI PRIBADI"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <!-- ===== CARD: INFO DETAIL ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row: Nama Lengkap -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nama Lengkap"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoNama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp" />

                <!-- Row: Username -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏷️"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Username"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/accent_green"
                            android:textSize="15sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp" />

                <!-- Row: Tempat Lahir -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tempat Lahir"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoTempatLahir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp" />

                <!-- Row: Tanggal Lahir -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tanggal Lahir"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoTanggalLahir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp" />

                <!-- Row: Hobi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hobi"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoHobi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider_color" android:layout_marginHorizontal="20dp" />

                <!-- Row: Bio -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️"
                        android:textSize="20sp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bio"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoBio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:layout_marginTop="2dp"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== TOMBOL EDIT PROFIL ===== -->
        <Button
            android:id="@+id/btnEditProfil"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:text="✏️  Edit Profil"
            android:textColor="#0D1117"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary" />

        <!-- ===== FOOTER ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="BudgetKu v1.0.0 • Mobile24SI3"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
