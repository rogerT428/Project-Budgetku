<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔀 Split Bill Baru"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Judul Split" android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etSplitTitle"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Contoh: Makan Siang, Biaya Liburan"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Total Tagihan (Rp)" android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etSplitTotal"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Masukkan total tagihan"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Nama Anggota (pisahkan dengan koma)" android:textColor="@color/text_secondary"
        android:textSize="13sp" android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etMemberNames"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Contoh: Andi, Budi, Cici, Dedi"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <!-- Auto-calculated per person -->
    <TextView
        android:id="@+id/tvCalculatedPerPerson"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/accent_green"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_chip_selected"
        android:layout_marginBottom="12dp"
        android:visibility="gone"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Catatan (opsional)" android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etSplitNotes"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Catatan tambahan..."
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:inputType="text"
        android:layout_marginBottom="20dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="2">

        <Button
            android:id="@+id/btnCancelSplit"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginEnd="8dp" android:text="Batal"
            android:textColor="@color/text_secondary" android:backgroundTint="@color/bg_card_elevated"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnCreateSplit"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="✅ Buat Split"
            android:textColor="@color/bg_primary" android:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>
