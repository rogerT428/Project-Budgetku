<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🗂️ Kelola Kategori"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tekan lama untuk menghapus kategori kustom"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"/>

    <!-- Category list -->
    <android.widget.ListView
        android:id="@+id/lvCategories"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:divider="@color/divider_color"
        android:dividerHeight="1dp"
        android:layout_marginBottom="16dp"/>

    <!-- Add new category -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Kategori Baru"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="8dp">

        <EditText android:id="@+id/etNewCategoryIcon"
            android:layout_width="60dp" android:layout_height="48dp"
            android:hint="🎯" android:textSize="20sp" android:gravity="center"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card" android:inputType="text"
            android:layout_marginEnd="8dp"/>

        <EditText android:id="@+id/etNewCategoryName"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:hint="Nama kategori"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_card" android:paddingHorizontal="12dp"
            android:inputType="text"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="2">

        <Button android:id="@+id/btnCloseCategories"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginEnd="8dp" android:text="Tutup"
            android:textColor="@color/text_secondary" android:backgroundTint="@color/bg_card_elevated"
            app:cornerRadius="12dp"/>

        <Button android:id="@+id/btnAddCategory"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="+ Tambah"
            android:textColor="@color/bg_primary" android:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>
