<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_card">

    <!-- Judul Dialog -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✏️  Edit Profil"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Tempat Lahir -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tempat Lahir"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etEditTempatLahir"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contoh: Jakarta"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        android:background="@drawable/bg_section_card"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Tanggal Lahir -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tanggal Lahir"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etEditTanggalLahir"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contoh: 1 Januari 2000"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        android:background="@drawable/bg_section_card"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Hobi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hobi"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etEditHobi"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contoh: Membaca, Coding, Olahraga"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        android:background="@drawable/bg_section_card"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Bio -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bio"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etEditBio"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="Ceritakan sedikit tentang dirimu..."
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        android:background="@drawable/bg_section_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginBottom="24dp" />

    <!-- Tombol Aksi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnBatalEditProfil"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Batal"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/bg_card_elevated"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSimpanEditProfil"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Simpan"
            android:textColor="#0D1117"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginStart="8dp" />

    </LinearLayout>
</LinearLayout>
