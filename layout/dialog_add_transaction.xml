<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Transaksi"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Amount Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jumlah (Rp)"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etTransactionAmount"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Masukkan jumlah"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:inputType="numberDecimal"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:textSize="18sp"
        android:layout_marginBottom="12dp"/>

    <!-- Category Spinner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kategori"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Description Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deskripsi (opsional)"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etTransactionDescription"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Catatan transaksi..."
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="16dp"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <!-- Toggle Type button -->
    <Button
        android:id="@+id/btnToggleType"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Ganti ke Pemasukan"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:backgroundTint="@color/bg_card_elevated"
        android:layout_marginBottom="12dp"
        app:cornerRadius="8dp"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCancelTransaction"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Batal"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/bg_card_elevated"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnSaveTransaction"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Simpan"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/accent_green"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</LinearLayout>
